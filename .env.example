# ── News API Keys ────────────────────────────────────────────────────────
# Primary: https://newsapi.org/register (free, 100 req/day)
VITE_NEWS_API_KEY=your_newsapi_key_here

# Fallback 1: https://gnews.io (500 req/day free, CORS-friendly)
VITE_GNEWS_KEY=your_gnews_key_here

# Fallback 2: https://open-platform.theguardian.com/access/ (free, unlimited)
VITE_GUARDIAN_KEY=your_guardian_key_here

# ── AI Chatbot ───────────────────────────────────────────────────────────
# https://huggingface.co/settings/tokens
VITE_AI_TOKEN=your_huggingface_token_here
